{
  "name": "sigaroute",
  "version": "1.0.0",
  "description": "Sistema de Gerenciamento de Rotas e Endereços",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "mocha test/**/*.test.js --reporter mochawesome --reporter-options reportDir=./mochawesome-report,reportFilename=report.html",
    "test:watch": "mocha test/**/*.test.js --watch",
    "test:coverage": "nyc mocha test/**/*.test.js"
  },
  "keywords": [
    "rotas",
    "endereços",
    "destinatários",
    "jwt",
    "autenticação"
  ],
  "author": "Jonas",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-validator": "^7.0.0",
    "jsonwebtoken": "^9.0.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "chai": "^4.3.10",
    "mocha": "^7.2.0",
    "mochawesome": "^1.5.5",
    "nodemon": "^3.1.14",
    "nyc": "^14.1.1",
    "supertest": "^6.3.3"
  }
}
